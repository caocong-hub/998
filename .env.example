# Copy this file to `.env` and fill in the values.

# -----------------------------------------------------------------------------
# MongoDB Atlas (recommended)
# -----------------------------------------------------------------------------
# 1. Sign in at https://www.mongodb.com/cloud/atlas and create a free M0 cluster.
# 2. Database Access: create a database user (username + password); use Read and write to any database.
# 3. Network Access: Add IP Address — for local dev you can use 0.0.0.0/0 or your current IP.
# 4. On the cluster page: Connect → Drivers → copy the connection string (mongodb+srv://...).
# 5. Replace <password> with your real password; URL-encode special characters in the password if needed.
# 6. Set a database name in the path (below: lms) and keep query params:
#
# DATABASE_URL="mongodb+srv://DB_USER:DB_PASSWORD@cluster0.xxxxx.mongodb.net/lms?retryWrites=true&w=majority"
#
# Prisma and Next.js both read DATABASE_URL from `.env`.
DATABASE_URL=

# -----------------------------------------------------------------------------
# NextAuth v5
# -----------------------------------------------------------------------------
# Generate a random secret, e.g. openssl rand -base64 32
AUTH_SECRET="replace-with-long-random-string"

# Production (Vercel): set to your public site URL so OAuth/callbacks work.
# AUTH_URL=https://your-app.vercel.app
# AUTH_TRUST_HOST=true

# -----------------------------------------------------------------------------
# Public app URL (used for shared links, e.g. course cards)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Optional: Google OAuth (omit for demo)
# -----------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Optional: LLM (Teaching Pathway, Personalized Generator, Course Suggestion,
# Emotion). Provider: OpenAI-compatible (default) or Google Gemini.
# -----------------------------------------------------------------------------
#
# --- Google Gemini (AI Studio API key) ---
# LLM_API_KEY=your-google-ai-studio-key
# Or: GEMINI_API_KEY=... (used if LLM_API_KEY is empty)
# LLM_MODEL=gemini-2.0-flash
# Omit LLM_BASE_URL to use Gemini automatically; or set LLM_PROVIDER=gemini
# if you also set LLM_BASE_URL for another tool.
# LLM_PROVIDER=gemini
#
# --- OpenAI-compatible (DeepSeek, Groq, etc.) ---
# LLM_PROVIDER=openai
# LLM_API_KEY=
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat
#
# Optional (both providers where applicable):
# LLM_TIMEOUT_MS=60000
# LLM_MAX_INPUT_CHARS=12000
# Gemini: JSON via responseMimeType; set false to disable strict JSON mode:
# LLM_USE_JSON_RESPONSE_FORMAT=true

# -----------------------------------------------------------------------------
# Optional: M2 trimodal emotion API (Python FastAPI in repo `m2/`, not on Vercel)
# -----------------------------------------------------------------------------
# M2_API_URL=http://127.0.0.1:8765
# Legacy fallback: M4_API_URL=http://127.0.0.1:8765

