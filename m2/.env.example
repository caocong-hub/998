# Copy to `.env` in this directory if you use python-dotenv with a loader, or export in shell before uvicorn.
# Default IEMOCAP sample data lives under ./sample_data/IEMOCAP
# IEMOCAP_ROOT=/absolute/path/to/IEMOCAP

# Fusion checkpoint (optional until you have trained weights)
# Default file: ./checkpoints/best_trimodal_model.pth (can be a symlink to ../best_trimodal_model_模型权重.pth)
# M2_CHECKPOINT_PATH=/absolute/path/to/best_trimodal_model.pth
# Example if weights live in repo root with Chinese filename:
# M2_CHECKPOINT_PATH=/Users/you/998/m2/best_trimodal_model_模型权重.pth

# CORS for FastAPI (comma-separated)
# M2_CORS_ORIGINS=http://localhost:3000
